// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UploadedFile {
  id        String   @id
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())
}

model User {
  id                     Int                    @id @default(autoincrement())
  username               String                 @unique
  email                  String                 @unique
  password               String
  isAdmin                Boolean                @default(false)
  createdAt              DateTime               @default(now())
  bio                    String?
  avatar                 String?
  banner                 String?
  coins                  Int                    @default(0)
  xp                     Int                    @default(0)
  level                  Int                    @default(1)
  currentStreak          Int                    @default(0)
  longestStreak          Int                    @default(0)
  lastStreakDate         DateTime?
  challenges             UserChallenge[]
  cosmetics              UserCosmetic[]
  createdChallenges      Challenge[]
  sentFriendRequests     Friend[]               @relation("SentRequests")
  receivedFriendRequests Friend[]               @relation("ReceivedRequests")
  createdGroups          ChallengeGroup[]       @relation("GroupCreator")
  groupMemberships       ChallengeGroupMember[]
  groupMessages          GroupMessage[]
  createdSeriesGroups    SeriesGroup[]          @relation("SeriesGroupCreator")
  seriesGroupMemberships SeriesGroupMember[]
  seriesGroupMessages    SeriesGroupMessage[]
}

model Friend {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("PENDING") // PENDING, ACCEPTED
  createdAt  DateTime @default(now())
  sender     User     @relation("SentRequests", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Challenge {
  id           Int              @id @default(autoincrement())
  title        String
  description  String
  difficulty   String // EASY, MEDIUM, HARD, EXPERT
  category     String // GAMING, SPORT, CUISINE, FITNESS, CREATIVITY, KNOWLEDGE, SOCIAL
  coinReward   Int
  xpReward     Int
  isDefault    Boolean          @default(false)
  isPublic     Boolean          @default(true)
  seriesName   String?
  createdBy    Int?
  createdAt    DateTime         @default(now())
  creator      User?            @relation(fields: [createdBy], references: [id])
  participants UserChallenge[]
  groups       ChallengeGroup[]

  @@index([seriesName])
}

model UserChallenge {
  id          Int       @id @default(autoincrement())
  userId      Int
  challengeId Int
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@index([userId, status])
}

model Cosmetic {
  id          Int            @id @default(autoincrement())
  name        String
  description String
  type        String // AVATAR_FRAME, BANNER, BADGE, TITLE
  imageUrl    String?
  price       Int
  rarity      String // COMMON, RARE, EPIC, LEGENDARY
  owners      UserCosmetic[]
}

model UserCosmetic {
  id          Int      @id @default(autoincrement())
  userId      Int
  cosmeticId  Int
  purchasedAt DateTime @default(now())
  equipped    Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])
  cosmetic    Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
}

model SeriesGroup {
  id          Int                  @id @default(autoincrement())
  seriesName  String
  createdBy   Int
  createdAt   DateTime             @default(now())
  completedAt DateTime?
  creator     User                 @relation("SeriesGroupCreator", fields: [createdBy], references: [id])
  members     SeriesGroupMember[]
  messages    SeriesGroupMessage[]
}

model SeriesGroupMember {
  id          Int         @id @default(autoincrement())
  groupId     Int
  userId      Int
  status      String      @default("INVITED") // INVITED, JOINED
  invitedAt   DateTime    @default(now())
  joinedAt    DateTime?
  confirmedAt DateTime?
  group       SeriesGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model SeriesGroupMessage {
  id        Int         @id @default(autoincrement())
  groupId   Int
  userId    Int
  content   String
  createdAt DateTime    @default(now())
  group     SeriesGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
}

model ChallengeGroup {
  id          Int                    @id @default(autoincrement())
  challengeId Int
  createdBy   Int
  createdAt   DateTime               @default(now())
  challenge   Challenge              @relation(fields: [challengeId], references: [id])
  creator     User                   @relation("GroupCreator", fields: [createdBy], references: [id])
  members     ChallengeGroupMember[]
  messages    GroupMessage[]
}

model ChallengeGroupMember {
  id          Int            @id @default(autoincrement())
  groupId     Int
  userId      Int
  status      String         @default("INVITED") // INVITED, JOINED, COMPLETED
  invitedAt   DateTime       @default(now())
  joinedAt    DateTime?
  completedAt DateTime?
  group       ChallengeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupMessage {
  id        Int            @id @default(autoincrement())
  groupId   Int
  userId    Int
  content   String
  createdAt DateTime       @default(now())
  group     ChallengeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id])
}
